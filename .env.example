FTP_HOST=example.com
FTP_REMOTE_DIR=demo/posokanei-basket
FTP_USER=your-ftp-user
# Use either FTP_PASS or FTP_KEYCHAIN_SERVICE.
# FTP_PASS=your-ftp-password
# FTP_KEYCHAIN_SERVICE=your-keychain-service-name
POSOKANEI_PUBLIC_CATALOG_URL=https://example.com/demo/posokanei-basket/data/catalog.json
# Optional: run the catalogue API fetch on another SSH host, then upload locally.
# POSOKANEI_REFRESH_HOST=runner-a
# Optional: try several SSH refresh runners in order. The first successful host wins.
# POSOKANEI_REFRESH_HOSTS=runner-a,runner-b
